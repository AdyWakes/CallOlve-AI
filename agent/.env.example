# The agent reads ../.env (the Next.js app's .env) automatically, so you usually
# don't need this file. Use it only to override these agent-specific values.

# Where the running CallOlve Next.js app is reachable from the worker.
# Local dev: the worker runs on your machine, so localhost is correct.
CALLEASE_API_URL=http://localhost:3000

# Pin a specific assistant (otherwise the first ACTIVE assistant is used).
# AGENT_ASSISTANT_ID=

# Deepgram model overrides (defaults are good).
# DEEPGRAM_STT_MODEL=nova-3
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en
