# Copy to .env and fill in values

# SQLite for local dev, PostgreSQL for production:
# DATABASE_URL="postgresql://user:password@localhost:5432/callease?schema=public"
DATABASE_URL="file:./dev.db"

# Required: session JWT signing secret (32+ random bytes)
AUTH_SECRET=""

# AI brain — GitHub Models (free). Token needs the "models" permission.
GITHUB_MODELS_TOKEN=""
GITHUB_MODELS_BASE_URL="https://models.github.ai/inference"
GITHUB_MODELS_MODEL="openai/gpt-4o-mini"

# Real phone path (Phase 2)
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
LIVEKIT_SIP_HOST=""

# Studio voice (Phase 2, free tiers)
DEEPGRAM_API_KEY=""
STT_PROVIDER="deepgram"
TTS_PROVIDER="deepgram"
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL="eleven_flash_v2_5"
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="centralindia"
AZURE_SPEECH_VOICE="en-IN-NeerjaNeural"

# Phone audio mode: "pipeline" = STT -> chat LLM -> TTS, "realtime" = direct speech model.
PHONE_AGENT_MODE="pipeline"
AZURE_OPENAI_ENDPOINT=""
REALTIME_BASE_URL=""
REALTIME_MODEL="gpt-realtime-2"
REALTIME_VOICE="marin"
REALTIME_REASONING_EFFORT="low"

# Phone agent server-to-server auth
AGENT_API_TOKEN=""
AGENT_USER_EMAIL="demo@callease.ai"
CALLEASE_API_URL="http://localhost:3020"

REDIS_URL=""
